# ===========================================
# 校园论坛安全配置模板
# 复制此文件为 .env 并填入实际值
# ===========================================

# 服务器配置
PORT=3000
NODE_ENV=production

# MongoDB 配置
MONGODB_URI=mongodb://localhost:27017/school-forum
MONGODB_USERNAME=
MONGODB_PASSWORD=
MONGODB_AUTHSOURCE=admin
# TLS/SSL（生产环境建议启用）
MONGODB_TLS=false
# MONGODB_TLS_CA_FILE=/path/to/ca.pem
# MONGODB_TLS_CERT_FILE=/path/to/client.pem
# MONGODB_TLS_ALLOW_INVALID_CERTS=false
# 连接池 & 超时（单位毫秒）
MONGODB_SERVER_SELECTION_TIMEOUT=10000
MONGODB_CONNECT_TIMEOUT=10000
MONGODB_SOCKET_TIMEOUT=30000
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=2

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# REDIS_USERNAME=          # Redis 6+ ACL 用户名（可选）
# REDIS_DB=0               # 使用的数据库编号
# REDIS_TLS=false          # 生产环境建议启用
REDIS_CONNECT_TIMEOUT=5000
REDIS_COMMAND_TIMEOUT=3000

# JWT 安全配置
# 请使用强随机字符串，建议 32 字符以上
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# 管理员 JWT 配置
ADMIN_JWT_SECRET=your-admin-jwt-secret-key-change-this
ADMIN_JWT_EXPIRES_IN=24h

# 邮件服务配置
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@163.com
SMTP_PASS=your-email-password-or-app-token

# CORS 白名单（多个域名用逗号分隔）
CORS_ORIGIN=http://localhost:2080,http://127.0.0.1:2080

# 安全配置
# 请求体大小限制（MB）
MAX_REQUEST_SIZE=10

# 登录失败锁定配置
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_TIME=1800000

# 密码策略
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL=false

# Rate Limit 配置
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# 安全头配置
CONTENT_SECURITY_POLICY=default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:;
